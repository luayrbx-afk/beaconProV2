local function isAlive(p)
    if not p or not p.Character then return false end
    local hum = p.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    return true
end
local function getMurderer()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and isAlive(v) then
            local bp = v:FindFirstChild("Backpack")
            if (bp and bp:FindFirstChild("Knife")) or v.Character:FindFirstChild("Knife") then return v end
        end
    end
    return nil
end
local function getSheriff()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and isAlive(v) then
            local bp = v:FindFirstChild("Backpack")
            if (bp and bp:FindFirstChild("Gun")) or v.Character:FindFirstChild("Gun") then return v end
        end
    end
    return nil
end
local function amIMurderer()
    if isAlive(lp) then
        local bp = lp:FindFirstChild("Backpack")
        if (bp and bp:FindFirstChild("Knife")) or lp.Character:FindFirstChild("Knife") then return true end
    end
    return false
end
local function findClosestSpawn()
    local closest = nil
    local dist = math.huge
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:lower():find("spawn") or v.Name == "Spawn") then
            local d = (hrp.Position - v.Position).Magnitude
            if d < dist then dist = d closest = v end
        end
    end
    return closest
end
local function teleportToSpawn()
    local target = nil
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:lower():find("spawn") or v.Name == "Spawn") then
            if (v.Position - LobbyCenter).Magnitude <= 500 then target = v break end
        end
    end
    if target and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        lp.Character.HumanoidRootPart.CFrame = target.CFrame + Vector3.new(0, 5, 0)
    end
end
local function teleportToMap()
    local target = nil
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:lower():find("spawn") or v.Name == "Spawn") then
            if (v.Position - LobbyCenter).Magnitude > 500 then target = v break end
        end
    end
    if target and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        lp.Character.HumanoidRootPart.CFrame = target.CFrame + Vector3.new(0, 5, 0)
    end
end
local function applyPlayerStats()
    local hum = lp.Character and lp.Character:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = _G.WalkSpeedValue hum.JumpPower = _G.JumpPowerValue hum.UseJumpPower = true end
end
lp.CharacterAdded:Connect(function(char)
    local hum = char:WaitForChild("Humanoid", 10)
    if hum then
        local t = 0
        local c; c = RunService.Heartbeat:Connect(function(dt)
            t = t + dt
            if t >= 0.5 then c:Disconnect() applyPlayerStats() end
        end)
    end
end)
local function getDroppedGun()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and v.Name == "GunDrop" then return v end
    end
    return nil
end
local function updateESP()
    if not _G.ESPEnabled then
        for i, h in pairs(espHighlights) do if h then h:Destroy() end end
        espHighlights = {}
        return
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp then
            if p.Character and isAlive(p) then
                if not espHighlights[p] or not espHighlights[p].Parent then
                    local h = Instance.new("Highlight")
                    h.FillTransparency = 0.5
                    h.OutlineTransparency = 0
                    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    h.Parent = p.Character
                    espHighlights[p] = h
                end
                local h = espHighlights[p]
                h.Parent = p.Character
                local bp = p:FindFirstChild("Backpack")
                local isM = (bp and bp:FindFirstChild("Knife")) or p.Character:FindFirstChild("Knife")
                local isS = (bp and bp:FindFirstChild("Gun")) or p.Character:FindFirstChild("Gun")
                if isM then h.FillColor = Color3.fromRGB(255, 0, 0)
                elseif isS then h.FillColor = Color3.fromRGB(0, 0, 255)
                else h.FillColor = Color3.fromRGB(0, 255, 0) end
            else
                if espHighlights[p] then espHighlights[p]:Destroy() espHighlights[p] = nil end
            end
        end
    end
    local gunDrop = getDroppedGun()
    if gunDrop then
        if not espHighlights["GunDrop"] or not espHighlights["GunDrop"].Parent then
            local h = Instance.new("Highlight")
            h.FillColor = Color3.fromRGB(255, 255, 0)
            h.FillTransparency = 0.2
            h.OutlineColor = Color3.fromRGB(255, 255, 255)
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            h.Parent = gunDrop
            espHighlights["GunDrop"] = h
        end
        espHighlights["GunDrop"].Parent = gunDrop
    else
        if espHighlights["GunDrop"] then espHighlights["GunDrop"]:Destroy() espHighlights["GunDrop"] = nil end
    end
end
local cachedCoins = {}
local lastCoinUpdate = 0
local function refreshCoins()
    cachedCoins = {}
    local container = workspace:FindFirstChild("Normal") and workspace.Normal:FindFirstChild("CoinContainer")
    if container then
        for _, v in pairs(container:GetChildren()) do
            table.insert(cachedCoins, v)
        end
    else
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and v:FindFirstChildWhichIsA("TouchTransmitter") then
                if v.Name:lower():match("coin") or (v.Parent and v.Parent.Name:lower():match("coin")) then
                    table.insert(cachedCoins, v)
                end
            end
        end
    end
end
local function getClosestCoinPart()
    if os.clock() - lastCoinUpdate > 1 then
        refreshCoins()
        lastCoinUpdate = os.clock()
    end
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local closest = nil
    local dist = math.huge
    for _, coin in pairs(cachedCoins) do
        if coin and coin.Parent then
            local targetPart = coin:IsA("BasePart") and coin or coin:FindFirstChildWhichIsA("BasePart")
            if targetPart then
                local d = (hrp.Position - targetPart.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = targetPart
                end
            end
        end
    end
    return closest
end
RunService.RenderStepped:Connect(function()
    updateESP()
    if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        if hrp.Position.Y < -40 and not _G.AutoFarmCoins and not _G.LoopFlingSelected then
            hrp.Velocity = Vector3.new(0, 0, 0)
            local spawnPart = findClosestSpawn()
            hrp.CFrame = spawnPart and (spawnPart.CFrame + Vector3.new(0, 5, 0)) or CFrame.new(0, 100, 0)
        end
        if _G.Noclip or _G.HiddenFling or _G.AutoFarmCoins or _G.LoopFlingSelected then
            for _, v in pairs(lp.Character:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end
end)
local function startFlingAction(targetPlayer)
    if Flinging or _G.LoopFlingSelected or not targetPlayer or not isAlive(targetPlayer) then return end
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    Flinging = true
    _G.HiddenFling = true
    local originalCF = hrp.CFrame
    local flingTime = 0
    local flingConn
    flingConn = RunService.Heartbeat:Connect(function(dt)
        flingTime = flingTime + dt
        if flingTime >= _G.FlingDuration or not isAlive(targetPlayer) or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            _G.HiddenFling = false
            flingConn:Disconnect()
            if hrp and hrp.Parent then
                hrp.Velocity = Vector3.new(0, 0, 0)
                hrp.RotVelocity = Vector3.new(0, 0, 0)
                hrp.Anchored = true
                local resetTime = 0
                local resetConn
                resetConn = RunService.Heartbeat:Connect(function(dt2)
                    resetTime = resetTime + dt2
                    if resetTime >= 0.5 then
                        resetConn:Disconnect()
                        if originalCF.Y < -30 then
                            local s = findClosestSpawn()
                            hrp.CFrame = s and (s.CFrame + Vector3.new(0, 5, 0)) or CFrame.new(0, 50, 0)
                        else hrp.CFrame = originalCF end
                        hrp.Anchored = false
                        Flinging = false
                    end
                end)
            end
            return
        end
        local tHRP = targetPlayer.Character.HumanoidRootPart
        local tHum = targetPlayer.Character:FindFirstChild("Humanoid")
        local movePredict = (tHum and tHum.MoveDirection * 2) or Vector3.new(0,0,0)
        if hrp and hrp.Parent then
            hrp.Velocity = Vector3.new(1000000, 1000000, 1000000)
            hrp.RotVelocity = Vector3.new(0, 1000000, 0)
            hrp.CFrame = tHRP.CFrame * CFrame.new(movePredict.X, 0, movePredict.Z) * CFrame.Angles(math.random(-360, 360), math.random(-360, 360), math.random(-360, 360))
        end
    end)
end
local function fireGun()
    if not isAlive(lp) or not lp.Character:FindFirstChild("HumanoidRootPart") then return end
    local gun = lp.Character:FindFirstChild("Gun") or lp:FindFirstChild("Backpack"):FindFirstChild("Gun")
    local m = getMurderer()
    if gun and m and isAlive(m) and m.Character:FindFirstChild("HumanoidRootPart") then
        local function doShoot()
            local mHRP = m.Character.HumanoidRootPart
            local targetPos = mHRP.Position + (mHRP.Velocity * 0.25)
            local args = {[1] = CFrame.new(mHRP.Position + Vector3.new(0,0,1), targetPos) * CFrame.Angles(1.453, 0.044, 1.65), [2] = CFrame.new(targetPos)}
            if gun:FindFirstChild("Shoot") then gun.Shoot:FireServer(unpack(args)) end
        end
        if gun.Parent == lp:FindFirstChild("Backpack") then
            lp.Character.Humanoid:EquipTool(gun)
            local t = 0
            local c; c = RunService.Heartbeat:Connect(function(dt)
                t = t + dt
                if t >= 0.1 then c:Disconnect() doShoot() end
            end)
        else doShoot() end
    end
end
local function throwAction()
    if not isAlive(lp) or not lp.Character:FindFirstChild("HumanoidRootPart") then return end
    local knife = lp.Character:FindFirstChild("Knife") or lp:FindFirstChild("Backpack"):FindFirstChild("Knife")
    local near, dist = nil, math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and isAlive(v) and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (lp.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d near = v end
        end
    end
    if knife and near and isAlive(near) and near.Character:FindFirstChild("HumanoidRootPart") then
        if knife.Parent == lp:FindFirstChild("Backpack") then lp.Character.Humanoid:EquipTool(knife) end
        local targetHRP = near.Character.HumanoidRootPart
        local args = {[1] = CFrame.new(targetHRP.Position + Vector3.new(0,0,3), targetHRP.Position) * CFrame.Angles(1.45, 0.04, 1.65), [2] = CFrame.new(targetHRP.Position)}
        if knife:FindFirstChild("Events") and knife.Events:FindFirstChild("KnifeThrown") then knife.Events.KnifeThrown:FireServer(unpack(args)) end
    end
end
local function grabGunAction()
    local gunObj = getDroppedGun()
    if gunObj and isAlive(lp) and lp.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        if typeof(firetouchinterest) == "function" then
            if gunObj:IsA("BasePart") then
                firetouchinterest(hrp, gunObj, 0)
                local c; c = RunService.Heartbeat:Connect(function() firetouchinterest(hrp, gunObj, 1) c:Disconnect() end)
            else
                for _, v in pairs(gunObj:GetDescendants()) do
                    if v:IsA("BasePart") then
                        firetouchinterest(hrp, v, 0)
                        local c; c = RunService.Heartbeat:Connect(function() firetouchinterest(hrp, v, 1) c:Disconnect() end)
                    end
                end
            end
        end
    end
end
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.F1 then local m = getMurderer() if m then startFlingAction(m) end
    elseif input.KeyCode == Enum.KeyCode.F2 then local s = getSheriff() if s then startFlingAction(s) end
    elseif input.KeyCode == Enum.KeyCode.Y then fireGun()
    elseif input.KeyCode == Enum.KeyCode.R then throwAction()
    elseif input.KeyCode == Enum.KeyCode.L then grabGunAction() end
end)
local autoGrabTimer = 0
RunService.Heartbeat:Connect(function(dt)
    autoGrabTimer = autoGrabTimer + dt
    if autoGrabTimer >= 0.25 then
        autoGrabTimer = 0
        if _G.AutoGrabGun and not amIMurderer() and isAlive(lp) then grabGunAction() end
    end
    if _G.AutoFarmCoins and isAlive(lp) and not _G.LoopFlingSelected and not Flinging then
        local hrp = lp.Character.HumanoidRootPart
        local coin = getClosestCoinPart()
        if coin then
            local dist = (coin.Position - hrp.Position).Magnitude
            local moveAmount = _G.AutoFarmSpeed * dt
            hrp.Velocity = Vector3.new(0, 0, 0)
            if dist > moveAmount then
                hrp.CFrame = CFrame.new(hrp.Position, coin.Position) * CFrame.new(0, 0, -moveAmount)
            else
                hrp.CFrame = coin.CFrame
                if typeof(firetouchinterest) == "function" then
                    firetouchinterest(hrp, coin, 0)
                    firetouchinterest(hrp, coin, 1)
                end
            end
        end
    end
    if _G.LoopFlingSelected and _G.TargetFling ~= "None" and not Flinging then
        local target = Players:FindFirstChild(_G.TargetFling)
        if target and isAlive(target) and isAlive(lp) then
            local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
            local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
            if tHRP and hrp then
                local params = RaycastParams.new()
                params.FilterType = Enum.RaycastFilterType.Exclude
                params.FilterDescendantsInstances = {target.Character, lp.Character}
                local hit = workspace:Raycast(tHRP.Position, Vector3.new(0, -55, 0), params)
                if hit then
                    local tHum = target.Character:FindFirstChild("Humanoid")
                    local movePredict = (tHum and tHum.MoveDirection * 2) or Vector3.new(0,0,0)
                    hrp.Velocity = Vector3.new(1000000, 1000000, 1000000)
                    hrp.RotVelocity = Vector3.new(0, 1000000, 0)
                    hrp.CFrame = tHRP.CFrame * CFrame.new(movePredict.X, 0, movePredict.Z) * CFrame.Angles(math.random(-360, 360), math.random(-360, 360), math.random(-360, 360))
                else
                    hrp.Velocity = Vector3.new(0,0,0)
                    hrp.RotVelocity = Vector3.new(0,0,0)
                end
            end
        end
    end
end)
RunService.Stepped:Connect(function()
    if lp.Character and (_G.AntiFling or _G.HiddenFling or _G.LoopFlingSelected) then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= lp and p.Character then
                for _, part in pairs(p.Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
            end
        end
    end
end)
local function makeDraggable(frame, button, customAction)
    local dragging, dragStart, startPos
    button.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            if customAction then customAction() end
            if not _G.LockAll then dragging = true dragStart = input.Position startPos = frame.Position end
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end
makeDraggable(ShootMurder_c, ClickDetector_14, fireGun)
makeDraggable(KnifeTrow_16, ClickDetector_1e, throwAction)
makeDraggable(GrabGun_2, ClickDetector_a, grabGunAction)
